# Required: VK community token with messages permissions.
VK_GROUP_TOKEN=vk1.a.your_group_token

# Required for standalone bridge security: comma-separated numeric VK user IDs.
# The bridge is default-deny unless VK_ALLOW_ALL_USERS=1 is set explicitly.
VK_ALLOWED_USERS=333222111,444555666
VK_ALLOW_ALL_USERS=0

# Optional: Hermes executable and runtime tuning.
HERMES_BIN=hermes
VK_HERMES_TIMEOUT_SEC=420
VK_HERMES_AUTO_YOLO=0
VK_HERMES_QUICK_TOOLSETS=clarify
VK_HERMES_FULL_TOOLSETS=web,browser,terminal,file,code_execution,vision,image_gen,tts,skills,todo,memory,session_search,clarify,delegation,cronjob,messaging

# Optional paths.
# VK_ENV_PATH=$HOME/.hermes/scripts/vk_bridge.env
# VK_STATE_PATH=$HOME/.hermes/state/vk_polling_state.json
# VK_LOG_PATH=$HOME/.hermes/logs/vk_polling_bridge.log
# VK_HEARTBEAT_PATH=$HOME/.hermes/state/vk_polling_heartbeat
# VK_INBOX_DIR=$HOME/.hermes/inbox/vk_bridge
